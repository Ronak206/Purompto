# ============================================
# Purompto Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# MongoDB Atlas (Required)
# --------------------------------------------
# Get your connection string from MongoDB Atlas Dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/purompto

# --------------------------------------------
# OpenRouter API (Required)
# --------------------------------------------
# Get your free API key from https://openrouter.ai/keys
# You can add multiple keys for fallback (recommended)
OPENROUTER_API_KEY_1=your-first-openrouter-api-key
OPENROUTER_API_KEY_2=your-second-openrouter-api-key
# Or use single key (backwards compatible)
# OPENROUTER_API_KEY=your-openrouter-api-key

# --------------------------------------------
# JWT Secret (Required)
# --------------------------------------------
# Generate a random secret key for JWT token signing
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# --------------------------------------------
# App URL (Required for Production)
# --------------------------------------------
# Your production URL (without trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# --------------------------------------------
# Admin Secret (Required for User Management)
# --------------------------------------------
# This secret key is used to access the admin panel at /admin
# Generate a strong random string: openssl rand -base64 32
ADMIN_SECRET=your-admin-secret-key-change-this

# --------------------------------------------
# Payment Gateway (Optional - for future use)
# --------------------------------------------
# Razorpay credentials if you want to enable payments later
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret-key
